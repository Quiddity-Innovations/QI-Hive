# QI Hive — gitignore
data/
logs/
LOGS/
archive/
__pycache__/
*.pyc
*.pyo
.venv/
node_modules/
.env
*.db
*.db-wal
*.db-shm
.claude/

# Local-only credentials store (LINE tokens, recovery codes, bot secrets)
# NEVER commit — keep entirely local
secrets/

# Auto-generated registry backups — local only
ecosystem/*.bak_*
ecosystem/*.backup-*

# Broker request queue + hive report queue — ephemeral, local only
commands/pending/
commands/completed/
commands/archive/
shared/reports/inbox/
shared/reports/archive/

# Brain vector memory + inbox — regeneratable / ephemeral, never commit
qi_memory/
**/qi_memory/
chroma/
**/chroma/
*.chroma
brain/inbox/
brain/inbox/processed/
brain/inbox/errors/

# UNIVERSAL→QIH Phase 1 migration — mirrored historical content (keep on disk, not in git)
# Allow .md design docs; ignore only binary/ephemeral subtrees
shared/documentation/session_summaries/
shared/documentation/*.docx
shared/documentation/*.py
shared/documentation/*.txt
shared/training/
shared/sessions_universal/
.claude_universal/
