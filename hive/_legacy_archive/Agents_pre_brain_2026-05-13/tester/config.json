    "Dashboard":  {"api": "http://localhost:8600", "ui": "http://localhost:8600"}
  },
  "result_dir": "C:\\Claude\\Tests\\results\\",
  "escalation_rules": {
    "critical": {"condition": "prod_service_failure", "priority": "high", "assign_to": "ops"},
