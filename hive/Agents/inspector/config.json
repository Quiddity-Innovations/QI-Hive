{
  "agent": "inspector",
  "model_default": "claude-sonnet-4-6",
  "model_max": "claude-sonnet-4-6",
  "status": "idle",
  "scope": "review-and-approval",
  "can_write_code": false,
  "can_run_bash": true,
  "bash_restrictions": [
    "read-only operations only",
    "may run qi_validator.py",
    "may run grep/glob searches",
    "no file modifications"
  ],
  "approval_required_for": [
    "any code that touches maia.db schema",
    "any new NSSM service registration",
    "any change to port assignments",
    "any file that handles user input from external channels"
  ],
  "escalate_to": "renne",
  "escalation_conditions": [
    "critical security vulnerability found",
    "proposed change would break a production service",
    "hardcoded secret detected in code"
  ]
}
