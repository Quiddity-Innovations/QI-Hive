{
  "_comment": "QI Elevation Broker — command whitelist. Only commands matching one of these rules are allowed to execute as SYSTEM. Patterns are regex. Each arg checked independently. Edit requires QI_Elevate service restart.",
  "rules": [
    {
      "name": "nssm_service_control",
      "description": "Start/stop/restart/query a QI_ service",
      "cmd": "nssm",
      "arg_count_min": 2,
      "arg_count_max": 2,
      "args_regex": [
        "^(start|stop|restart|status|pause|continue)$",
        "^QI_[A-Za-z0-9_]+$"
      ]
    },
    {
      "name": "nssm_set_appdir",
      "description": "Repoint a QI_ service AppDirectory under C:\\QIH or C:\\QIP",
      "cmd": "nssm",
      "arg_count_min": 4,
      "arg_count_max": 4,
      "args_regex": [
        "^set$",
        "^QI_[A-Za-z0-9_]+$",
        "^AppDirectory$",
        "^C:\\\\(QIH|QIP)(\\\\[A-Za-z0-9_.-]+)*$"
      ]
    },
    {
      "name": "nssm_set_appparams",
      "description": "Repoint a QI_ service AppParameters under C:\\QIH or C:\\QIP",
      "cmd": "nssm",
      "arg_count_min": 4,
      "arg_count_max": 4,
      "args_regex": [
        "^set$",
        "^QI_[A-Za-z0-9_]+$",
        "^AppParameters$",
        "^C:\\\\(QIH|QIP)(\\\\[A-Za-z0-9_.-]+)*\\.(py|bat)$"
      ]
    },
    {
      "name": "nssm_set_description",
      "description": "Update a QI_ service description string",
      "cmd": "nssm",
      "arg_count_min": 4,
      "arg_count_max": 4,
      "args_regex": [
        "^set$",
        "^QI_[A-Za-z0-9_]+$",
        "^Description$",
        "^.{1,200}$"
      ]
    },
    {
      "name": "sc_service_control",
      "description": "Start/stop/query a QI_ service via sc.exe (fallback path when nssm hits DACL issues)",
      "cmd": "sc",
      "arg_count_min": 2,
      "arg_count_max": 2,
      "args_regex": [
        "^(start|stop|query|queryex|continue|pause)$",
        "^QI_[A-Za-z0-9_]+$"
      ]
    },
    {
      "name": "taskkill_by_pid",
      "description": "Force-kill a process by PID",
      "cmd": "taskkill",
      "arg_count_min": 3,
      "arg_count_max": 3,
      "args_regex": [
        "^/PID$",
        "^[0-9]+$",
        "^/F$"
      ]
    },
    {
      "name": "gsudo_config_set",
      "description": "Set a gsudo configuration value",
      "cmd": "gsudo",
      "arg_count_min": 3,
      "arg_count_max": 3,
      "args_regex": [
        "^config$",
        "^(CacheMode|CacheDuration|LogLevel|SecurityEnforceUacIsolation|NewWindow\\.Force)$",
        "^(Auto|Explicit|Disabled|Infinite|All|Debug|Info|Warning|Error|None|True|False|[0-9]{2}:[0-9]{2}:[0-9]{2})$"
      ]
    },
    {
      "name": "gsudo_cache_control",
      "description": "Start or stop the gsudo credentials cache",
      "cmd": "gsudo",
      "arg_count_min": 2,
      "arg_count_max": 2,
      "args_regex": [
        "^cache$",
        "^(on|off)$"
      ]
    },
    {
      "name": "gsudo_invalidate_cache",
      "description": "Invalidate all gsudo cached credentials",
      "cmd": "gsudo",
      "arg_count_min": 1,
      "arg_count_max": 1,
      "args_regex": [
        "^-k$"
      ]
    }
  ]
}
